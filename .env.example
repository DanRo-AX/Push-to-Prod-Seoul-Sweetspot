# .env.example

# Anthropic API 키 (필수) — https://platform.claude.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# 콜드메일 실발송 허용 수신자 화이트리스트 (쉼표 구분).
# 비어 있으면 발송은 항상 모의(mock) 처리된다. 데모 당일 사내 데모 계정만 넣을 것.
OCTOPUS_EMAIL_WHITELIST=demo@example.com

# 기본 시나리오 팩 (A-zero-to-one | B-rebrand)
OCTOPUS_SCENARIO=A-zero-to-one
